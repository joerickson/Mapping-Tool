# App
VITE_APP_URL=https://geo.rbmservicesinc.com

# Supabase — client-side (public)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Supabase — server-side (secret)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Signup — set to "true" to enable the /signup page; otherwise shows "Contact your admin"
VITE_ALLOW_SIGNUP=false

# Mapbox — used client-side and for embed/map server rendering
VITE_MAPBOX_ACCESS_TOKEN=pk.eyJ1...
MAPBOX_ACCESS_TOKEN=pk.eyJ1...

# Google Maps
GOOGLE_MAPS_API_KEY=AIza...

# Regrid Parcel API
REGRID_API_KEY=...
# Cost per Regrid API fallback call in USD (default: 0.05)
REGRID_API_COST_USD=0.05
# Fallback calls per county (90-day window) before "buy this county" alert fires
PARCEL_FALLBACK_THRESHOLD=50

# Admin notification email — receives "buy this county" alerts via Resend
ADMIN_NOTIFICATION_EMAIL=admin@rbmservicesinc.com

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Webhook destinations
RBM_CRM_WEBHOOK_URL=https://...
RBM_BID_MANAGER_WEBHOOK_URL=https://...

# Per-consumer webhook signing secrets (HMAC-SHA256)
RBM_CRM_WEBHOOK_SECRET=whsec_...
RBM_BID_MANAGER_WEBHOOK_SECRET=whsec_...

# Service-to-service API auth (legacy fallback; use service_api_keys table for production)
SERVICE_API_KEY=rbm_svc_...

# Deep link base URLs for CRM / Bid Manager
VITE_RBM_CRM_BASE_URL=https://crm.rbmservicesinc.com
VITE_RBM_BID_MANAGER_BASE_URL=https://bids.rbmservicesinc.com

# Resend (transactional email) — optional
RESEND_API_KEY=re_...
